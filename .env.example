# ─────────────────────────────────────────────────────────────────────────────
# .env — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit this file to Git! Add .env to your .gitignore
# Copy this file to .env and fill in your real values.
# ─────────────────────────────────────────────────────────────────────────────

# ── SERVER ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── DATABASE ──────────────────────────────────────────────────────────────────
# MongoDB connection string
# Format: mongodb://HOST:PORT/DATABASE_NAME or your MongoDB Atlas URI
# Example local: mongodb://localhost:27017/ebook_library
MONGODB_URI="mongodb://localhost:27017/ebook_library"

# ── SESSION ───────────────────────────────────────────────────────────────────
# A long random string used to sign session cookies
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="change-this-to-a-long-random-secret-string"

# ── GOOGLE OAUTH ─────────────────────────────────────────────────────────────
# Get these from https://console.cloud.google.com/
# 1. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client
# 2. Add callback URL: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── EMAIL NOTIFICATIONS ───────────────────────────────────────────────────────
# For sending reading reminders via email
# Use Gmail with an App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
EMAIL_FROM="eBook Library <your-email@gmail.com>"

# ── APP URL ───────────────────────────────────────────────────────────────────
# The public URL of your app (used for OAuth callbacks and email links)
APP_URL="http://localhost:3000"
