// prisma/schema.prisma
// ─────────────────────────────────────────────────────────────────────────────
// This file defines your DATABASE STRUCTURE.
// Prisma reads this file and generates:
//   1. The actual PostgreSQL tables (via migrations)
//   2. A TypeScript/JS client to query those tables
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite — zero installation needed, perfect for local development
  // The database file will be created at prisma/dev.db
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── USER TABLE ────────────────────────────────────────────────────────────────
// Every person who registers gets a row here.
// "?" means the field is optional (can be NULL in the database).
model User {
  id            Int       @id @default(autoincrement()) // Auto-incrementing primary key
  email         String    @unique                        // Must be unique — no two users share an email
  username      String    @unique
  passwordHash  String?   // Null if user signed up via Google OAuth
  googleId      String?   @unique // Google's unique ID for OAuth users
  avatar        String?   // URL to profile picture
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Reading preferences stored as JSON (font size, theme, etc.)
  preferences   String    @default("{}")  // JSON string — SQLite doesn't support Json type natively

  // ── RELATIONS ─────────────────────────────────────────────────────────────
  // These tell Prisma "this user has MANY of these things"
  readingHistory  ReadingHistory[]
  notifications   Notification[]
  bookmarks       Bookmark[]
  readingGoals    ReadingGoal[]
}

// ── READING HISTORY TABLE ─────────────────────────────────────────────────────
// Every time a user opens a book, we log it here.
// This powers the recommendation engine — "you read X, you might like Y"
model ReadingHistory {
  id              Int       @id @default(autoincrement())
  userId          Int
  gutenbergId     Int       // The book's ID from Project Gutenberg API
  title           String
  author          String?
  coverUrl        String?
  subjects        String    @default("[]") // JSON string — SQLite doesn't support native arrays
  
  // How far the user got through the book (0–100%)
  progressPercent Int       @default(0)
  
  // Total seconds the user spent reading this book
  totalReadSeconds Int      @default(0)
  
  lastReadAt      DateTime  @default(now())
  firstReadAt     DateTime  @default(now())
  
  // Completed = user reached 90%+ or manually marked as done
  completed       Boolean   @default(false)
  
  // User's star rating (1–5), null if not rated yet
  rating          Int?

  // "userId" foreign key — links back to the User table
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite unique: one row per user+book combination
  @@unique([userId, gutenbergId])
  @@index([userId])
}

// ── BOOKMARK TABLE ────────────────────────────────────────────────────────────
// Users can save books to read later
model Bookmark {
  id          Int       @id @default(autoincrement())
  userId      Int
  gutenbergId Int
  title       String
  author      String?
  coverUrl    String?
  savedAt     DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, gutenbergId])
}

// ── NOTIFICATION TABLE ────────────────────────────────────────────────────────
// In-app notifications: reading reminders, new recommendations, etc.
model Notification {
  id        Int       @id @default(autoincrement())
  userId    Int
  type      String    // "reminder" | "recommendation" | "achievement" | "system"
  title     String
  body      String
  read      Boolean   @default(false)  // Has the user seen this?
  link      String?   // Optional URL to navigate to when clicked
  createdAt DateTime  @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, read])
}

// ── READING GOAL TABLE ────────────────────────────────────────────────────────
// Users can set goals like "read 20 books this year" or "read 30 mins/day"
model ReadingGoal {
  id          Int       @id @default(autoincrement())
  userId      Int
  type        String    // "books_per_month" | "minutes_per_day" | "books_per_year"
  target      Int       // e.g., 20 (books) or 30 (minutes)
  current     Int       @default(0) // Progress toward the goal
  period      String    // "daily" | "monthly" | "yearly"
  startDate   DateTime  @default(now())
  endDate     DateTime?
  achieved    Boolean   @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
}
